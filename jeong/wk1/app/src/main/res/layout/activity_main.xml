<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="26dp"
        android:background="@android:color/transparent"
        android:contentDescription="뒤로가기"
        android:padding="2dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp"

        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintVertical_bias="0.5">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘 하루는 어땠나요?"
            android:fontFamily="@font/titlefont"
            android:textColor="#000000"
            android:textSize="30sp"
            android:textStyle="normal"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="감정우표를 선택해주세요"
            android:fontFamily="@font/titlefont"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="normal"
            android:textAlignment="center"
            android:lineHeight="25sp"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="선택한 감정우표를 기반으로 맞춤형 질문이 배달됩니다"
            android:fontFamily="@font/scdream"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="normal"
            android:textAlignment="center"
            android:lineHeight="12sp"
            android:includeFontPadding="false" />

        <LinearLayout
            android:id="@+id/layoutHappy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="27dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivHappy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="행복"
                android:src="@drawable/ic_stamp_happy" />

            <TextView
                android:id="@+id/tvHappy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="더없이 행복한 하루였어요"
                android:fontFamily="@font/titlefont"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textAlignment="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutExcited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivExcited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="들뜸"
                android:src="@drawable/ic_stamp_excited" />

            <TextView
                android:id="@+id/tvExcited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="들뜨고 흥분돼요"
                android:fontFamily="@font/titlefont"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textAlignment="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutNormal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="평범"
                android:src="@drawable/ic_stamp_normal" />

            <TextView
                android:id="@+id/tvNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="평범한 하루였어요"
                android:fontFamily="@font/titlefont"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textAlignment="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutAnxious"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivAnxious"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="불안"
                android:src="@drawable/ic_stamp_anxious" />

            <TextView
                android:id="@+id/tvAnxious"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="생각이 많아지고 불안해요"
                android:fontFamily="@font/titlefont"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textAlignment="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutAngry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivAngry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="화남"
                android:src="@drawable/ic_stamp_angry" />

            <TextView
                android:id="@+id/tvAngry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="부글부글 화가 나요"
                android:fontFamily="@font/titlefont"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textAlignment="center" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>